{
  "main": "./lib/keytar.js",
  "typings": "keytar.d.ts",
  "name": "@guocity/keytar",
  "description": "Bindings to native Mac/Linux/Windows password APIs",
  "version": "7.9.3",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guocity/node-keytar.git"
  },
  "bugs": {
    "url": "https://github.com/guocity/node-keytar/issues"
  },
  "homepage": "https://github.com/guocity/node-keytar",
  "keywords": [
    "keychain",
    "password",
    "passwords",
    "credential",
    "credentials",
    "vault",
    "credential vault"
  ],
  "files": [
    "lib",
    "src",
    "binding.gyp",
    "keytar.d.ts"
  ],
  "types": "./keytar.d.ts",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "install": "prebuild-install || npm run build",
    "build": "node-gyp rebuild",
    "lint": "npm run cpplint",
    "cpplint": "node-cpplint --filters legal-copyright,build-include,build-namespaces src/*.cc",
    "test": "npm run lint && npm rebuild && mocha spec/",
    "prebuild-napi-x64": "prebuild -t 3 -r napi -a x64 --strip",
    "prebuild-napi-ia32": "prebuild -t 3 -r napi -a ia32 --strip",
    "prebuild-napi-arm64": "prebuild -t 3 -r napi -a arm64 --strip",
    "prebuild-napi-armv7l": "prebuild -t 3 -r napi -a armv7l --strip",
    "upload": "node ./script/upload.js",
    "release": "bash ./script/release.sh",
    "release:minor": "bash ./script/release.sh minor",
    "release:major": "bash ./script/release.sh major",
    "release:current": "bash ./script/release.sh current"
  },
  "devDependencies": {
    "chai": "^4.5.0",
    "mocha": "^11.7.6",
    "node-cpplint": "~0.4.0",
    "node-gyp": "^12.4.0",
    "prebuild": "^13.0.1"
  },
  "dependencies": {
    "node-addon-api": "^8.9.0",
    "prebuild-install": "^7.1.3"
  },
  "overrides": {
    "request": "npm:@cypress/request@^4.0.1",
    "tar": "^7.5.19",
    "semver": "^7.8.5",
    "qs": "^6.15.3",
    "tough-cookie": "^6.0.2",
    "uuid": "^14.0.1",
    "form-data": "^4.0.6",
    "serialize-javascript": "^7.0.7",
    "diff": "^9.0.0"
  },
  "binary": {
    "napi_versions": [
      3
    ]
  },
  "config": {
    "runtime": "napi",
    "target": 3
  }
}
